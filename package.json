{
  "name": "dlvideo",
  "version": "2.0.0",
  "description": "视频下载工具 - 支持 YouTube、B站等平台",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "prepare:asr-binaries": "node scripts/prepare-asr-binaries.js",
    "build:main": "node scripts/build-main.js",
    "build:main:dev": "node scripts/build-main.js --dev",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer && electron-builder",
    "preview": "vite preview",
    "rebuild": "npx @electron/rebuild -f -w better-sqlite3",
    "electron:dev": "npm run prepare:asr-binaries && npm run build:main:dev && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run prepare:asr-binaries && npm run build:main && npm run build:renderer && electron-builder",
    "postinstall": "npx @electron/rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "youtube",
    "bilibili",
    "downloader",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.27.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "yt-dlp-wrap": "^2.3.12",
    "zustand": "^4.4.7"
  },
  "build": {
    "appId": "com.dlvideo.app",
    "productName": "DLVideo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/lib",
        "to": "lib",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
